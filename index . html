<style>
  :root{
    --white: #FFFFFF;
    --offwhite: #F4F6FA;
    --black: #0A0B0E;
    --black-soft: #14161B;
    --line: #E7EAF0;
    --line-dark: #23262E;
    --text: #14161B;
    --muted: #5B6270;
    --muted-dark: #9AA1AF;
    --blue: #1657FF;
    --blue-deep: #0A2E8C;
    --blue-glow: #4FC9FF;
  }

  * { margin:0; padding:0; box-sizing:border-box; }
  html { scroll-behavior: smooth; }

  body{
    background: var(--white);
    color: var(--text);
    font-family: 'Montserrat', sans-serif;
    line-height: 1.5;
    overflow-x: hidden;
  }

  @media (prefers-reduced-motion: reduce){
    * { animation-duration: 0.001ms !important; transition-duration: 0.001ms !important; }
  }

  a { color: inherit; text-decoration: none; }
  ::selection { background: rgba(22,87,255,0.18); color: var(--text); }
  a:focus-visible, button:focus-visible { outline: 2px solid var(--blue); outline-offset: 3px; }

  .wrap{ max-width: 1180px; margin: 0 auto; padding: 0 32px; }

  .eyebrow{
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--blue);
  }

  /* ---------- NAV ---------- */
  header{
    position: fixed; top:0; left:0; right:0; z-index: 100;
    background: var(--black);
    border-bottom: 1px solid var(--line-dark);
  }
  nav{
    display:flex; align-items:center; justify-content:space-between;
    padding: 14px 32px;
    max-width: 1180px; margin: 0 auto;
  }
  .brand{ display:flex; align-items:center; gap: 12px; }
  .brand img{ height: 44px; width: 44px; border-radius: 8px; object-fit: cover; }
  .brand-text{ font-weight: 800; font-size: 17px; color: #fff; letter-spacing: 0.01em; }
  .brand-text span{ color: var(--blue-glow); font-weight: 600; }

  .nav-links{ display:flex; gap: 34px; font-size: 14px; color: var(--muted-dark); }
  .nav-links a:hover{ color: #fff; }
  .nav-cta{
    background: var(--blue);
    color: #fff;
    padding: 10px 22px;
    border-radius: 3px;
    font-size: 13px;
    font-weight: 700;
    transition: background 0.25s;
  }
  .nav-cta:hover{ background: var(--blue-deep); }

  /* ---------- HERO ---------- */
  .hero{
    position: relative;
    padding: 200px 0 120px;
    background: var(--white);
    border-bottom: 1px solid var(--line);
    overflow: hidden;
  }
  .hero-glow{
    position: absolute;
    top: -220px; right: -180px;
    width: 560px; height: 560px;
    background: radial-gradient(circle, rgba(22,87,255,0.14) 0%, rgba(22,87,255,0) 70%);
    pointer-events: none;
  }
  .hero-inner{ position: relative; }
  .hero .eyebrow{ display:block; margin-bottom: 24px; }

  .headline{
    font-weight: 800;
    font-size: clamp(38px, 6vw, 68px);
    line-height: 1.08;
    letter-spacing: -0.01em;
    max-width: 820px;
  }
  .headline em{
    font-style: normal;
    color: var(--blue);
  }

  .hero-sub{
    margin-top: 28px;
    max-width: 620px;
    color: var(--muted);
    font-size: 17px;
  }

  .hero-actions{ margin-top: 44px; display:flex; align-items:center; gap: 26px; flex-wrap: wrap; }

  .btn-primary{
    background: var(--blue);
    color: #fff;
    padding: 16px 32px;
    font-size: 14px;
    font-weight: 700;
    border-radius: 3px;
    letter-spacing: 0.01em;
    display: inline-block;
    transition: transform 0.25s ease, box-shadow 0.25s ease, background 0.25s ease;
  }
  .btn-primary:hover{
    background: var(--blue-deep);
    transform: translateY(-2px);
    box-shadow: 0 12px 28px -10px rgba(22,87,255,0.5);
  }

  .btn-outline{
    border: 1.5px solid var(--black);
    color: var(--black);
    padding: 14.5px 30px;
    font-size: 14px;
    font-weight: 700;
    border-radius: 3px;
    transition: background 0.25s, color 0.25s;
  }
  .btn-outline:hover{ background: var(--black); color: #fff; }

  /* ---------- MARQUEE ---------- */
  .marquee-section{
    background: var(--black);
    padding: 18px 0;
    overflow: hidden;
  }
  .marquee-track{
    display: flex; gap: 56px; white-space: nowrap;
    animation: scroll-left 30s linear infinite;
    width: max-content;
  }
  .marquee-track span{
    font-size: 13px; font-weight: 700; letter-spacing: 0.08em;
    text-transform: uppercase; color: var(--muted-dark);
  }
  .marquee-track span em{ color: var(--blue-glow); font-style: normal; }
  @keyframes scroll-left{ from{ transform: translateX(0); } to{ transform: translateX(-50%); } }

  /* ---------- SECTION HEADER ---------- */
  .section{ padding: 110px 0; }
  .section-head{
    display:flex; justify-content: space-between; align-items: flex-end; gap: 40px;
    margin-bottom: 64px; border-bottom: 2px solid var(--black); padding-bottom: 28px;
  }
  .section-title{
    font-weight: 800;
    font-size: clamp(28px, 3.6vw, 42px);
    max-width: 560px;
  }
  .section-note{ max-width: 320px; color: var(--muted); font-size: 14px; text-align: right; }

  /* ---------- SERVICES ---------- */
  .services{
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px;
    background: var(--line); border: 1px solid var(--line);
  }
  .service-card{ background: var(--white); padding: 44px 36px; transition: background 0.3s ease; }
  .service-card:hover{ background: var(--offwhite); }
  .service-index{ font-size: 13px; font-weight: 800; color: var(--blue); letter-spacing: 0.08em; }
  .service-title{ font-size: 21px; font-weight: 700; margin: 18px 0 12px; }
  .service-desc{ color: var(--muted); font-size: 14.5px; }

  /* ---------- PROCESS ---------- */
  .process-list{ border-top: 1px solid var(--line); }
  .process-row{
    display: grid; grid-template-columns: 90px 1fr 1fr; gap: 40px; align-items: center;
    padding: 38px 0; border-bottom: 1px solid var(--line);
  }
  .process-num{ font-weight: 800; color: var(--blue); font-size: 15px; }
  .process-title{ font-size: 22px; font-weight: 700; }
  .process-desc{ color: var(--muted); font-size: 14.5px; max-width: 460px; }

  /* ---------- STATS ---------- */
  .stats{ background: var(--black); padding: 90px 0; }
  .stats-grid{ display: grid; grid-template-columns: repeat(4, 1fr); gap: 32px; }
  .stat-num{ font-weight: 800; font-size: clamp(34px, 4.6vw, 50px); color: var(--blue-glow); }
  .stat-label{ margin-top: 8px; font-size: 13px; color: var(--muted-dark); }

  /* ---------- QUOTE ---------- */
  .quote-section{ padding: 130px 0; text-align:center; background: var(--offwhite); }
  .quote-text{
    font-weight: 700; font-size: clamp(24px, 3.2vw, 36px);
    max-width: 800px; margin: 0 auto; line-height: 1.35;
  }
  .quote-text em{ color: var(--blue); font-style: normal; }
  .quote-attr{ margin-top: 26px; color: var(--muted); font-size: 14px; font-weight: 600; }

  /* ---------- CTA / CONTACT ---------- */
  .cta-section{ background: var(--black); padding: 120px 0 100px; }
  .cta-title{
    font-weight: 800; font-size: clamp(30px, 4.6vw, 52px); max-width: 700px; line-height: 1.1; color: #fff;
  }
  .cta-title em{ color: var(--blue-glow); font-style: normal; }

  .contact-grid{
    margin-top: 56px;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--line-dark);
    border: 1px solid var(--line-dark);
  }
  .contact-card{ background: var(--black-soft); padding: 30px; }
  .contact-label{ font-size: 12px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted-dark); }
  .contact-value{ margin-top: 10px; font-size: 18px; font-weight: 700; color: #fff; }
  .contact-value a:hover{ color: var(--blue-glow); }
  .badge-24h{
    display:inline-block; margin-top: 10px; font-size: 12px; font-weight: 700;
    color: var(--blue-glow); border: 1px solid rgba(79,201,255,0.4); padding: 4px 10px; border-radius: 20px;
  }

  /* ---------- FOOTER ---------- */
  footer{ background: var(--black); border-top: 1px solid var(--line-dark); padding: 64px 0 40px; }

  .newsletter{
    display:flex; justify-content: space-between; align-items: flex-end; gap: 40px; flex-wrap: wrap;
    padding-bottom: 48px; margin-bottom: 40px; border-bottom: 1px solid var(--line-dark);
  }
  .newsletter-copy{ max-width: 420px; }
  .newsletter-title{ font-size: 20px; font-weight: 800; color: #fff; }
  .newsletter-sub{ margin-top: 8px; font-size: 13.5px; color: var(--muted-dark); }
  .newsletter-form{ display:flex; gap: 12px; flex-wrap: wrap; }
  .newsletter-form input[type="email"]{
    background: var(--black-soft);
    border: 1px solid var(--line-dark);
    color: #fff;
    padding: 13px 16px;
    font-family: 'Montserrat', sans-serif;
    font-size: 14px;
    border-radius: 3px;
    min-width: 260px;
    outline: none;
  }
  .newsletter-form input[type="email"]::placeholder{ color: var(--muted-dark); }
  .newsletter-form input[type="email"]:focus{ border-color: var(--blue); }
  .newsletter-form button{
    background: var(--blue);
    color: #fff;
    border: none;
    padding: 13px 26px;
    font-family: 'Montserrat', sans-serif;
    font-size: 14px;
    font-weight: 700;
    border-radius: 3px;
    cursor: pointer;
    transition: background 0.25s;
  }
  .newsletter-form button:hover{ background: var(--blue-deep); }
  .newsletter-note{
    margin-top: 10px;
    font-size: 12px;
    color: var(--muted-dark);
    min-height: 16px;
  }
  .newsletter-note.success{ color: var(--blue-glow); }

  .footer-inner{
    display:flex; justify-content: space-between; align-items:center; flex-wrap: wrap; gap: 20px;
    font-size: 13px; color: var(--muted-dark);
  }
  .footer-inner a:hover{ color: #fff; }
  .footer-brand{ display:flex; align-items:center; gap: 10px; }
  .footer-brand img{ height: 30px; width: 30px; border-radius: 6px; }

  /* ---------- WHATSAPP FLOATING BUTTON ---------- */
  .whatsapp-fab{
    position: fixed;
    bottom: 26px;
    right: 26px;
    z-index: 200;
    display:flex;
    align-items:center;
    gap: 10px;
    background: #25D366;
    color: #fff;
    padding: 14px 20px;
    border-radius: 50px;
    font-size: 14px;
    font-weight: 700;
    box-shadow: 0 10px 30px -8px rgba(37,211,102,0.55);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  .whatsapp-fab:hover{ transform: translateY(-3px); box-shadow: 0 16px 36px -8px rgba(37,211,102,0.65); }
  .whatsapp-fab svg{ width: 22px; height: 22px; flex-shrink: 0; }
  .whatsapp-fab .fab-text{ white-space: nowrap; }

  @media (max-width: 500px){
    .whatsapp-fab .fab-text{ display:none; }
    .whatsapp-fab{ padding: 14px; }
  }

  /* ---------- RESPONSIVE ---------- */
  @media (max-width: 860px){
    .nav-links{ display:none; }
    .services{ grid-template-columns: 1fr; }
    .stats-grid{ grid-template-columns: repeat(2, 1fr); row-gap: 36px; }
    .process-row{ grid-template-columns: 1fr; gap: 8px; }
    .section-head{ flex-direction: column; align-items: flex-start; }
    .section-note{ text-align: left; }
    .contact-grid{ grid-template-columns: 1fr; }
    .hero{ padding: 150px 0 90px; }
    .section{ padding: 80px 0; }
  }
</style>
